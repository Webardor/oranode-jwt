PORT=3000

DB_USER=your_oracle_user
DB_PASSWORD=your_oracle_password
DB_CONNECT_STRING=host:1521/service_name
ORACLE_CLIENT_LIB=C:\path\to\instantclient

# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_plus_character_secret
JWT_REFRESH_SECRET=replace_with_different_64_plus_character_secret

# Comma-separate multiple origins if needed.
ALLOWED_ORIGIN=http://localhost:5173
